{
  "manifest_version": 3,
  "name": "FImgSave Pro",
  "version": "1.0.0",
  "description": "Effortlessly crop, scale, convert, and save any web image as a high-quality PNG, JPEG, or WebP.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "contextMenus",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  }
}